# ---------- Orchestrator ----------
BOOKSTACK_URL=http://bookstack
BOOKSTACK_TOKEN_ID=replace-with-bookstack-token-id
BOOKSTACK_TOKEN_SECRET=replace-with-bookstack-token-secret
CONFIG_BOOK_NAME=Bookstack Orchestrator Config Book
CONFIG_PAGE_NAME=Bookstack Orchestrator Config
PAGE_RECIPES={}
LOG_LEVEL=warning

# ---------- BookStack ----------
BOOKSTACK_APP_URL=http://localhost:6875
BOOKSTACK_APP_KEY=base64:replace-with-generated-app-key

# ---------- Database ----------
DB_HOST=bookstack-db
DB_PORT=3306
DB_DATABASE=bookstackapp
DB_USERNAME=bookstack
DB_PASSWORD=replace-with-db-password
MYSQL_ROOT_PASSWORD=replace-with-root-password
